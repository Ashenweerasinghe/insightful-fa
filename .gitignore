# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# lighthouse reports (Phase 6) — keep numeric baseline in PROGRESS.md
/lighthouse/

# Claude Code session/runtime state (locks, local settings) — keep launch.json (shared preview config)
/.claude/*
!/.claude/launch.json

# QA snapshot artifacts (scripts/qa-snapshots.mjs)
/qa/

# typescript
*.tsbuildinfo
next-env.d.ts
