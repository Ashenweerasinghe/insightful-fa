# Public site URL — used by metadataBase, the sitemap absolute URLs,
# robots.txt's Sitemap line, and the Article JSON-LD canonical / publisher logo.
# Required in production; dev falls back to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=https://insightfulfa.com

# Web3Forms access key — powers the Contact form submission (POST to
# api.web3forms.com). The key is public-safe by design (it only permits
# sending to the address registered with Web3Forms). Get it from web3forms.com.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key
